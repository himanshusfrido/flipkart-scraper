# ScrapingBee (optional fallback — 1000 free calls)
SCRAPINGBEE_API_KEY=

# Crawlbase (optional fallback — 1000 free requests)
CRAWLBASE_TOKEN=

# Google Sheets — base64 encoded service account JSON key
GOOGLE_SHEETS_CREDS=

# Google Sheet ID — from your spreadsheet URL
GOOGLE_SHEET_ID=

# Slack incoming webhook URL
SLACK_WEBHOOK_URL=
